[package]
name = "{{ project_name }}"
version = "0.1.0"
edition = "2024"

[dependencies]
axum = "0.8"
tokio = { version = "1.52", features = ["full"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
dotenvy = "0.15"
{% if database %}
sqlx = { version = "0.9", features = ["sqlite", "runtime-tokio", "tls-native-tls"] }
{% endif %}